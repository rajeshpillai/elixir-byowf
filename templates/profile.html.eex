<!DOCTYPE html>
<html>
<head>
  <title>User Profile — Ignite</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 600px; margin: 50px auto; }
    h1 { color: #e74c3c; }
    .info { background: #f8f9fa; padding: 16px; border-radius: 8px; }
  </style>
</head>
<body>
  <h1>User Profile</h1>
  <div class="info">
    <p><strong>Name:</strong> <%= @name %></p>
    <p><strong>ID:</strong> <%= @id %></p>
    <p><strong>Server Time:</strong> <%= DateTime.utc_now() %></p>
  </div>
  <p><a href="/">Back to Home</a></p>
</body>
</html>
